# Copy ONCE at the repository root only:
#   cp .env.example .env
# Do not create packages/*/.env or apps/*/.env copies (pnpm env:check enforces this).

# --- Database (required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# --- Valkey (recommended — distributed rate limits + form cache; docker: valkey) ---
VALKEY_URL=redis://localhost:6379

# --- Security (recommended — salts terminal id / IP for one-submit-per-form dedup) ---
IP_HASH_SALT=change-me-in-production

# --- API hardening (optional) ---
# JSON_BODY_LIMIT=512kb
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300

# --- API server (optional — these are the defaults) ---
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development

# --- Next.js → API (required for home page health check) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc
# Live analytics WebSocket (optional — derived from API URL if omitted)
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/analytics
# Auth must hit the web app origin so session cookies stay on :3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
# Upstream API for Next.js /api/auth rewrites (apps/web/next.config.js)
AUTH_SERVER_URL=http://localhost:8000

# --- Web app origin (API CORS + Better Auth trusted origins) ---
WEB_APP_URL=http://localhost:3000

# --- Better Auth ---
BETTER_AUTH_SECRET=change-this-to-a-random-secret-in-production

# --- Google OAuth ---
# Use real values from Google Cloud Console when you wire auth.
# In Google Cloud → APIs & Services → Credentials → your OAuth client →
# Authorized redirect URIs, add EXACTLY (redirect_uri_mismatch if missing):
#   http://localhost:3000/api/auth/callback/google
# Open the app at http://localhost:3000 (not :8000, not 127.0.0.1 unless you register that too).
GOOGLE_OAUTH_CLIENT_ID=placeholder
GOOGLE_OAUTH_CLIENT_SECRET=placeholder
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# --- Logger (optional) ---
LOGGER_LEVEL=debug

# --- Email (Resend — optional until Phase 8 testing) ---
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
